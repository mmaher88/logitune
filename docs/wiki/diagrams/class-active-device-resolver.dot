digraph G {
    rankdir=LR;
    bgcolor="#0f172a";
    splines=true;
    nodesep=0.35;
    ranksep=1.8;
    newrank=true;
    compound=true;
    node [shape=plain, fontname="Inter, Segoe UI, sans-serif", fontsize=11, margin=0];
    edge [fontname="Inter, Segoe UI, sans-serif", fontsize=10, fontcolor="#cbd5e1"];

    // ============ ViewModel column ============
    subgraph cluster_vm {
        label=<<font color="#7dd3fc" point-size="12"><b>  ViewModel  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        DM [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">DeviceModel</font></b></td></tr>
                <tr><td bgcolor="#1e3a5f" port="selectedChanged"><font color="#7dd3fc" point-size="9">signal  </font><font color="#e2e8f0">selectedChanged</font></td></tr>
                <tr><td bgcolor="#1e3a5f" port="devices"><font color="#7dd3fc" point-size="9">method  </font><font color="#e2e8f0">devices</font></td></tr>
            </table>
        >];
    }

    // ============ Services column ============
    subgraph cluster_svc {
        label=<<font color="#c4b5fd" point-size="12"><b>  Services  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        ADR [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="6" bgcolor="#334155" color="#8b5cf6">
              <tr><td bgcolor="#334155" border="0"><b><font point-size="14" color="#f1f5f9">ActiveDeviceResolver</font></b></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Methods</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="activeDevice"><font color="#e2e8f0">activeDevice</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left"><font color="#e2e8f0">activeSession</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left"><font color="#e2e8f0">activeSerial</font></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Slots</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="onSelectionIndexChanged"><font color="#e2e8f0">onSelectionIndexChanged</font></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Signals</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="selectionChanged"><font color="#e2e8f0">selectionChanged</font></td></tr>
            </table>
        >];

        AR [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">AppRoot</font></b></td></tr>
                <tr><td bgcolor="#3f3a5e" port="onSelectionChanged"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">onSelectionChanged</font></td></tr>
            </table>
        >];

        { rank=same; ADR; AR; }
    }

    // ============ Signals ============
    DM:selectedChanged:e -> ADR:onSelectionIndexChanged:w [color="#7dd3fc"];
    ADR:selectionChanged:e -> AR:onSelectionChanged:w      [color="#c4b5fd", constraint=false];
    ADR:activeDevice:e     -> DM:devices:e                 [color="#7dd3fc", style=dashed, dir=back, label=<<font color="#94a3b8">reads</font>>];
}
