digraph G {
    rankdir=LR;
    bgcolor="#0f172a";
    splines=true;
    nodesep=0.35;
    ranksep=1.8;
    newrank=true;
    compound=true;
    node [shape=plain, fontname="Inter, Segoe UI, sans-serif", fontsize=11, margin=0];
    edge [fontname="Inter, Segoe UI, sans-serif", fontsize=10, fontcolor="#cbd5e1"];

    // ============ ViewModel column ============
    subgraph cluster_vm {
        label=<<font color="#7dd3fc" point-size="12"><b>  ViewModel  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        DM [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">DeviceModel</font></b></td></tr>
                <tr><td bgcolor="#1e3a5f" port="selectedChanged"><font color="#7dd3fc" point-size="9">signal  </font><font color="#e2e8f0">selectedChanged</font></td></tr>
            </table>
        >];
    }

    // ============ Services / Coordinator column ============
    subgraph cluster_svc {
        label=<<font color="#c4b5fd" point-size="12"><b>  Composition Root  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        ADR [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">ActiveDeviceResolver</font></b></td></tr>
                <tr><td bgcolor="#3f3a5e" port="onSelectionIndexChanged"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">onSelectionIndexChanged</font></td></tr>
            </table>
        >];

        AR  [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="6" bgcolor="#334155" color="#8b5cf6">
              <tr><td bgcolor="#334155" border="0"><b><font point-size="14" color="#f1f5f9">AppRoot</font></b></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Methods</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left"><font color="#e2e8f0">init</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left"><font color="#e2e8f0">startMonitoring</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left"><font color="#e2e8f0">wireSignals</font></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Slots</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="onPhysicalDeviceAdded"><font color="#e2e8f0">onPhysicalDeviceAdded</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="onPhysicalDeviceRemoved"><font color="#e2e8f0">onPhysicalDeviceRemoved</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="onSelectionChanged"><font color="#e2e8f0">onSelectionChanged</font></td></tr>
            </table>
        >];

        DF [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">DeviceFetcher</font></b></td></tr>
                <tr><td bgcolor="#1e3a2f" port="descriptorsUpdated"><font color="#6ee7b7" point-size="9">signal  </font><font color="#e2e8f0">descriptorsUpdated</font></td></tr>
                <tr><td bgcolor="#1e3a2f" port="fetchForPid"><font color="#6ee7b7" point-size="9">slot  </font><font color="#e2e8f0">fetchForPid</font></td></tr>
            </table>
        >];

        { rank=same; ADR; AR; DF; }
    }

    // ============ Core column ============
    subgraph cluster_core {
        label=<<font color="#fcd34d" point-size="12"><b>  Core  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        DMGR [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">DeviceManager</font></b></td></tr>
                <tr><td bgcolor="#3f301e" port="physicalDeviceAdded"><font color="#fcd34d" point-size="9">signal  </font><font color="#e2e8f0">physicalDeviceAdded</font></td></tr>
                <tr><td bgcolor="#3f301e" port="physicalDeviceRemoved"><font color="#fcd34d" point-size="9">signal  </font><font color="#e2e8f0">physicalDeviceRemoved</font></td></tr>
                <tr><td bgcolor="#3f301e" port="unknownDeviceDetected"><font color="#fcd34d" point-size="9">signal  </font><font color="#e2e8f0">unknownDeviceDetected</font></td></tr>
            </table>
        >];
        PD [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">PhysicalDevice</font></b></td></tr>
                <tr><td bgcolor="#3f301e" port="transportSetupComplete"><font color="#fcd34d" point-size="9">signal  </font><font color="#e2e8f0">transportSetupComplete</font></td></tr>
                <tr><td bgcolor="#3f301e" port="gestureRawXY"><font color="#fcd34d" point-size="9">signal  </font><font color="#e2e8f0">gestureRawXY</font></td></tr>
                <tr><td bgcolor="#3f301e" port="divertedButtonPressed"><font color="#fcd34d" point-size="9">signal  </font><font color="#e2e8f0">divertedButtonPressed</font></td></tr>
                <tr><td bgcolor="#3f301e" port="thumbWheelRotation"><font color="#fcd34d" point-size="9">signal  </font><font color="#e2e8f0">thumbWheelRotation</font></td></tr>
            </table>
        >];
        { rank=same; DMGR; PD; }
    }

    // ============ Signals ============
    DM:selectedChanged:e        -> ADR:onSelectionIndexChanged:w  [color="#7dd3fc"];
    DM:selectedChanged:e        -> AR:onSelectionChanged:w        [color="#7dd3fc"];

    AR:onPhysicalDeviceAdded:e   -> DMGR:physicalDeviceAdded:w     [color="#fcd34d", dir=back];
    AR:onPhysicalDeviceRemoved:e -> DMGR:physicalDeviceRemoved:w   [color="#fcd34d", dir=back];

    DMGR:unknownDeviceDetected:w -> DF:fetchForPid:e               [color="#fcd34d", constraint=false];
    DF:descriptorsUpdated:w      -> AR:onSelectionChanged:w        [color="#6ee7b7", constraint=false, style=dashed, label=<<font color="#94a3b8">reloads registry</font>>];

    AR:onPhysicalDeviceAdded:e   -> PD:transportSetupComplete:w    [color="#fcd34d", dir=back, style=dashed, label=<<font color="#94a3b8">per-device wiring</font>>];
}
