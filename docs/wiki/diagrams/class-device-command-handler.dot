digraph G {
    rankdir=LR;
    bgcolor="#0f172a";
    splines=true;
    nodesep=0.35;
    ranksep=1.8;
    newrank=true;
    compound=true;
    node [shape=plain, fontname="Inter, Segoe UI, sans-serif", fontsize=11, margin=0];
    edge [fontname="Inter, Segoe UI, sans-serif", fontsize=10, fontcolor="#cbd5e1"];

    // ============ ViewModel column ============
    subgraph cluster_vm {
        label=<<font color="#7dd3fc" point-size="12"><b>  ViewModel  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        DM [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">DeviceModel</font></b></td></tr>
                <tr><td bgcolor="#1e3a5f" port="dpiChangeRequested"><font color="#7dd3fc" point-size="9">signal  </font><font color="#e2e8f0">dpiChangeRequested</font></td></tr>
                <tr><td bgcolor="#1e3a5f" port="smartShiftChangeRequested"><font color="#7dd3fc" point-size="9">signal  </font><font color="#e2e8f0">smartShiftChangeRequested</font></td></tr>
                <tr><td bgcolor="#1e3a5f" port="scrollConfigChangeRequested"><font color="#7dd3fc" point-size="9">signal  </font><font color="#e2e8f0">scrollConfigChangeRequested</font></td></tr>
                <tr><td bgcolor="#1e3a5f" port="thumbWheelModeChangeRequested"><font color="#7dd3fc" point-size="9">signal  </font><font color="#e2e8f0">thumbWheelModeChangeRequested</font></td></tr>
                <tr><td bgcolor="#1e3a5f" port="thumbWheelInvertChangeRequested"><font color="#7dd3fc" point-size="9">signal  </font><font color="#e2e8f0">thumbWheelInvertChangeRequested</font></td></tr>
            </table>
        >];
    }

    // ============ Services column ============
    subgraph cluster_svc {
        label=<<font color="#c4b5fd" point-size="12"><b>  Services  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        ADR [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">ActiveDeviceResolver</font></b></td></tr>
                <tr><td bgcolor="#3f3a5e" port="activeSession"><font color="#c4b5fd" point-size="9">method  </font><font color="#e2e8f0">activeSession</font></td></tr>
            </table>
        >];

        DCH [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="6" bgcolor="#334155" color="#8b5cf6">
              <tr><td bgcolor="#334155" border="0"><b><font point-size="14" color="#f1f5f9">DeviceCommandHandler</font></b></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Slots</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="requestDpi"><font color="#e2e8f0">requestDpi</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="requestSmartShift"><font color="#e2e8f0">requestSmartShift</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="requestScrollConfig"><font color="#e2e8f0">requestScrollConfig</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="requestThumbWheelMode"><font color="#e2e8f0">requestThumbWheelMode</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="requestThumbWheelInvert"><font color="#e2e8f0">requestThumbWheelInvert</font></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Signals</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="userChangedSomething"><font color="#e2e8f0">userChangedSomething</font></td></tr>
            </table>
        >];

        PO [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">ProfileOrchestrator</font></b></td></tr>
                <tr><td bgcolor="#3f3a5e" port="saveCurrentProfile"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">saveCurrentProfile</font></td></tr>
            </table>
        >];

        { rank=same; ADR; DCH; PO; }
    }

    // ============ Core column ============
    subgraph cluster_core {
        label=<<font color="#fcd34d" point-size="12"><b>  Core  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        DS [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">DeviceSession</font></b></td></tr>
                <tr><td bgcolor="#3f301e" port="setDPI"><font color="#fcd34d" point-size="9">method  </font><font color="#e2e8f0">setDPI</font></td></tr>
                <tr><td bgcolor="#3f301e" port="setSmartShift"><font color="#fcd34d" point-size="9">method  </font><font color="#e2e8f0">setSmartShift</font></td></tr>
                <tr><td bgcolor="#3f301e" port="setScrollConfig"><font color="#fcd34d" point-size="9">method  </font><font color="#e2e8f0">setScrollConfig</font></td></tr>
                <tr><td bgcolor="#3f301e" port="setThumbWheelMode"><font color="#fcd34d" point-size="9">method  </font><font color="#e2e8f0">setThumbWheelMode</font></td></tr>
            </table>
        >];
    }

    // ============ Signals ============
    DM:dpiChangeRequested:e              -> DCH:requestDpi:w              [color="#7dd3fc"];
    DM:smartShiftChangeRequested:e       -> DCH:requestSmartShift:w       [color="#7dd3fc"];
    DM:scrollConfigChangeRequested:e     -> DCH:requestScrollConfig:w     [color="#7dd3fc"];
    DM:thumbWheelModeChangeRequested:e   -> DCH:requestThumbWheelMode:w   [color="#7dd3fc"];
    DM:thumbWheelInvertChangeRequested:e -> DCH:requestThumbWheelInvert:w [color="#7dd3fc"];

    DCH:userChangedSomething:e -> PO:saveCurrentProfile:w [color="#c4b5fd", constraint=false];

    DCH:requestDpi:e             -> ADR:activeSession:w [color="#c4b5fd", style=dashed, constraint=false, label=<<font color="#94a3b8">resolve</font>>];

    DCH:requestDpi:e             -> DS:setDPI:w            [color="#fcd34d", style=dashed, label=<<font color="#94a3b8">direct call</font>>];
    DCH:requestSmartShift:e      -> DS:setSmartShift:w     [color="#fcd34d", style=dashed];
    DCH:requestScrollConfig:e    -> DS:setScrollConfig:w   [color="#fcd34d", style=dashed];
    DCH:requestThumbWheelMode:e  -> DS:setThumbWheelMode:w [color="#fcd34d", style=dashed];
}
