digraph G {
    rankdir=LR;
    bgcolor="#0f172a";
    splines=true;
    nodesep=0.35;
    ranksep=1.8;
    newrank=true;
    compound=true;
    node [shape=plain, fontname="Inter, Segoe UI, sans-serif", fontsize=11, margin=0];
    edge [fontname="Inter, Segoe UI, sans-serif", fontsize=10, fontcolor="#cbd5e1"];

    // ============ Services column ============
    subgraph cluster_svc {
        label=<<font color="#c4b5fd" point-size="12"><b>  Composition Root  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        AR [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">AppRoot</font></b></td></tr>
                <tr><td bgcolor="#3f3a5e" port="onPhysicalDeviceAdded"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">onPhysicalDeviceAdded</font></td></tr>
                <tr><td bgcolor="#3f3a5e" port="onPhysicalDeviceRemoved"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">onPhysicalDeviceRemoved</font></td></tr>
            </table>
        >];

        DF [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">DeviceFetcher</font></b></td></tr>
                <tr><td bgcolor="#3f3a5e" port="fetchForPid"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">fetchForPid</font></td></tr>
            </table>
        >];

        { rank=same; AR; DF; }
    }

    // ============ Core column ============
    subgraph cluster_core {
        label=<<font color="#fcd34d" point-size="12"><b>  Core  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        DREG [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">DeviceRegistry</font></b></td></tr>
                <tr><td bgcolor="#3f301e" port="findByPid"><font color="#fcd34d" point-size="9">method  </font><font color="#e2e8f0">findByPid</font></td></tr>
            </table>
        >];

        DMGR [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="6" bgcolor="#334155" color="#8b5cf6">
              <tr><td bgcolor="#334155" border="0"><b><font point-size="14" color="#f1f5f9">DeviceManager</font></b></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Methods</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left"><font color="#e2e8f0">start</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="simulateAllFromRegistry"><font color="#e2e8f0">simulateAllFromRegistry</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="physicalDevices"><font color="#e2e8f0">physicalDevices</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left"><font color="#e2e8f0">physicalDeviceBySerial</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="sessions"><font color="#e2e8f0">sessions</font></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Signals</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="physicalDeviceAdded"><font color="#e2e8f0">physicalDeviceAdded(dev)</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="physicalDeviceRemoved"><font color="#e2e8f0">physicalDeviceRemoved(dev)</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="unknownDeviceDetected"><font color="#e2e8f0">unknownDeviceDetected(pid)</font></td></tr>
            </table>
        >];

        PD [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">PhysicalDevice</font></b></td></tr>
                <tr><td bgcolor="#3f301e" port="attachTransport"><font color="#fcd34d" point-size="9">method  </font><font color="#e2e8f0">attachTransport</font></td></tr>
                <tr><td bgcolor="#3f301e" port="detachTransport"><font color="#fcd34d" point-size="9">method  </font><font color="#e2e8f0">detachTransport</font></td></tr>
            </table>
        >];

        DS [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">DeviceSession</font></b></td></tr>
                <tr><td bgcolor="#3f301e" port="enumerateAndSetup"><font color="#fcd34d" point-size="9">method  </font><font color="#e2e8f0">enumerateAndSetup</font></td></tr>
            </table>
        >];

        { rank=same; DREG; DMGR; PD; DS; }
    }

    // ============ Signals ============
    DMGR:physicalDeviceAdded:w    -> AR:onPhysicalDeviceAdded:e    [color="#c4b5fd"];
    DMGR:physicalDeviceRemoved:w  -> AR:onPhysicalDeviceRemoved:e  [color="#c4b5fd"];
    DMGR:unknownDeviceDetected:w  -> DF:fetchForPid:e              [color="#c4b5fd"];

    DMGR:physicalDevices:e  -> PD:attachTransport:w   [color="#fcd34d", style=dashed, label=<<font color="#94a3b8">owns + attaches</font>>];
    DMGR:sessions:e         -> DS:enumerateAndSetup:w [color="#fcd34d", style=dashed, label=<<font color="#94a3b8">creates + enumerates</font>>];
    DMGR:simulateAllFromRegistry:e -> DREG:findByPid:w [color="#fcd34d", style=dashed, label=<<font color="#94a3b8">reads</font>>];
}
