digraph G {
    rankdir=LR;
    bgcolor="#0f172a";
    splines=true;
    nodesep=0.35;
    ranksep=1.8;
    newrank=true;
    compound=true;
    node [shape=plain, fontname="Inter, Segoe UI, sans-serif", fontsize=11, margin=0];
    edge [fontname="Inter, Segoe UI, sans-serif", fontsize=10, fontcolor="#cbd5e1"];

    // ============ Services column ============
    subgraph cluster_svc {
        label=<<font color="#c4b5fd" point-size="12"><b>  Services  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        DCH [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">DeviceCommandHandler</font></b></td></tr>
                <tr><td bgcolor="#3f3a5e" port="requestDpi"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">requestDpi</font></td></tr>
                <tr><td bgcolor="#3f3a5e" port="requestSmartShift"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">requestSmartShift</font></td></tr>
                <tr><td bgcolor="#3f3a5e" port="requestScrollConfig"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">requestScrollConfig</font></td></tr>
                <tr><td bgcolor="#3f3a5e" port="requestThumbWheelMode"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">requestThumbWheelMode</font></td></tr>
            </table>
        >];

        PO [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">ProfileOrchestrator</font></b></td></tr>
                <tr><td bgcolor="#3f3a5e" port="applyProfileToHardware"><font color="#c4b5fd" point-size="9">method  </font><font color="#e2e8f0">applyProfileToHardware</font></td></tr>
            </table>
        >];

        { rank=same; DCH; PO; }
    }

    // ============ Core column ============
    subgraph cluster_core {
        label=<<font color="#fcd34d" point-size="12"><b>  Core  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        CP [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">CommandProcessor</font></b></td></tr>
                <tr><td bgcolor="#3f301e" port="enqueue"><font color="#fcd34d" point-size="9">method  </font><font color="#e2e8f0">enqueue</font></td></tr>
            </table>
        >];

        FD [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">FeatureDispatcher</font></b></td></tr>
                <tr><td bgcolor="#3f301e" port="send"><font color="#fcd34d" point-size="9">method  </font><font color="#e2e8f0">send</font></td></tr>
            </table>
        >];

        TR [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">Transport</font></b></td></tr>
                <tr><td bgcolor="#3f301e" port="write"><font color="#fcd34d" point-size="9">method  </font><font color="#e2e8f0">write</font></td></tr>
            </table>
        >];

        DS  [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="6" bgcolor="#334155" color="#8b5cf6">
              <tr><td bgcolor="#334155" border="0"><b><font point-size="14" color="#f1f5f9">DeviceSession</font></b></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Methods</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="setDPI"><font color="#e2e8f0">setDPI</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="setSmartShift"><font color="#e2e8f0">setSmartShift</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="setScrollConfig"><font color="#e2e8f0">setScrollConfig</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="setThumbWheelMode"><font color="#e2e8f0">setThumbWheelMode</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="divertButton"><font color="#e2e8f0">divertButton</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="cycleDpi"><font color="#e2e8f0">cycleDpi</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="enumerateAndSetup"><font color="#e2e8f0">enumerateAndSetup</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="flushCommandProcessor"><font color="#e2e8f0">flushCommandProcessor</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="handleNotification"><font color="#e2e8f0">handleNotification</font></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Signals</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="setupComplete"><font color="#e2e8f0">setupComplete</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="disconnected"><font color="#e2e8f0">disconnected</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="gestureRawXY"><font color="#e2e8f0">gestureRawXY</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="divertedButtonPressed"><font color="#e2e8f0">divertedButtonPressed</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="thumbWheelRotation"><font color="#e2e8f0">thumbWheelRotation</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="batteryChanged"><font color="#e2e8f0">batteryChanged</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="smartShiftChanged"><font color="#e2e8f0">smartShiftChanged</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="currentDPIChanged"><font color="#e2e8f0">currentDPIChanged</font></td></tr>
            </table>
        >];

        PD [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">PhysicalDevice</font></b></td></tr>
                <tr><td bgcolor="#3f301e" port="onSetupComplete"><font color="#fcd34d" point-size="9">slot  </font><font color="#e2e8f0">onSetupComplete</font></td></tr>
                <tr><td bgcolor="#3f301e" port="onGestureRawXY"><font color="#fcd34d" point-size="9">slot  </font><font color="#e2e8f0">onGestureRawXY</font></td></tr>
                <tr><td bgcolor="#3f301e" port="onDivertedButtonPressed"><font color="#fcd34d" point-size="9">slot  </font><font color="#e2e8f0">onDivertedButtonPressed</font></td></tr>
                <tr><td bgcolor="#3f301e" port="onThumbWheelRotation"><font color="#fcd34d" point-size="9">slot  </font><font color="#e2e8f0">onThumbWheelRotation</font></td></tr>
                <tr><td bgcolor="#3f301e" port="onBatteryChanged"><font color="#fcd34d" point-size="9">slot  </font><font color="#e2e8f0">onBatteryChanged</font></td></tr>
            </table>
        >];

        { rank=same; CP; FD; TR; DS; PD; }
    }

    // ============ Signals ============
    // Services call DeviceSession setters
    DCH:requestDpi:e              -> DS:setDPI:w             [color="#c4b5fd", style=dashed, label=<<font color="#94a3b8">call</font>>];
    DCH:requestSmartShift:e       -> DS:setSmartShift:w      [color="#c4b5fd", style=dashed];
    DCH:requestScrollConfig:e     -> DS:setScrollConfig:w    [color="#c4b5fd", style=dashed];
    DCH:requestThumbWheelMode:e   -> DS:setThumbWheelMode:w  [color="#c4b5fd", style=dashed];
    PO:applyProfileToHardware:e   -> DS:setDPI:w             [color="#c4b5fd", style=dashed];

    // DeviceSession delegates writes through feature stack
    DS:setDPI:e             -> CP:enqueue:w [color="#fcd34d", style=dashed, label=<<font color="#94a3b8">enqueue</font>>];
    DS:setSmartShift:e      -> FD:send:w    [color="#fcd34d", style=dashed, label=<<font color="#94a3b8">send</font>>];
    DS:handleNotification:e -> TR:write:w   [color="#fcd34d", style=dashed, dir=back, label=<<font color="#94a3b8">reports in</font>>];

    // DeviceSession signals to PhysicalDevice fan-in
    DS:setupComplete:e         -> PD:onSetupComplete:w         [color="#fcd34d"];
    DS:gestureRawXY:e          -> PD:onGestureRawXY:w          [color="#fcd34d"];
    DS:divertedButtonPressed:e -> PD:onDivertedButtonPressed:w [color="#fcd34d"];
    DS:thumbWheelRotation:e    -> PD:onThumbWheelRotation:w    [color="#fcd34d"];
    DS:batteryChanged:e        -> PD:onBatteryChanged:w        [color="#fcd34d"];
}
