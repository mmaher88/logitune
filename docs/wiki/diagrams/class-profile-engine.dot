digraph G {
    rankdir=LR;
    bgcolor="#0f172a";
    splines=true;
    nodesep=0.35;
    ranksep=1.8;
    newrank=true;
    compound=true;
    node [shape=plain, fontname="Inter, Segoe UI, sans-serif", fontsize=11, margin=0];
    edge [fontname="Inter, Segoe UI, sans-serif", fontsize=10, fontcolor="#cbd5e1"];

    // ============ Services column ============
    subgraph cluster_svc {
        label=<<font color="#c4b5fd" point-size="12"><b>  Services  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        PO [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">ProfileOrchestrator</font></b></td></tr>
                <tr><td bgcolor="#3f3a5e" port="onDisplayProfileChanged"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">onDisplayProfileChanged</font></td></tr>
                <tr><td bgcolor="#3f3a5e" port="saveCurrentProfile"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">saveCurrentProfile</font></td></tr>
                <tr><td bgcolor="#3f3a5e" port="setupProfileForDevice"><font color="#c4b5fd" point-size="9">method  </font><font color="#e2e8f0">setupProfileForDevice</font></td></tr>
                <tr><td bgcolor="#3f3a5e" port="onWindowFocusChanged"><font color="#c4b5fd" point-size="9">slot  </font><font color="#e2e8f0">onWindowFocusChanged</font></td></tr>
            </table>
        >];

        BAD [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">ButtonActionDispatcher</font></b></td></tr>
                <tr><td bgcolor="#3f3a5e" port="readProfile"><font color="#c4b5fd" point-size="9">method  </font><font color="#e2e8f0">reads current profile</font></td></tr>
            </table>
        >];

        AR [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="7" bgcolor="#334155" color="#475569">
                <tr><td bgcolor="#334155" border="0"><b><font color="#f1f5f9">AppRoot</font></b></td></tr>
                <tr><td bgcolor="#3f3a5e" port="onProfileAddedRemoved"><font color="#c4b5fd" point-size="9">lambda  </font><font color="#e2e8f0">on ProfileModel add/remove</font></td></tr>
            </table>
        >];

        { rank=same; PO; BAD; AR; }
    }

    // ============ Core column ============
    subgraph cluster_core {
        label=<<font color="#fcd34d" point-size="12"><b>  Core  </b></font>>;
        bgcolor="#1e293b";
        color="#475569";
        penwidth=1;
        style="rounded,filled";

        PE  [label=<
            <table border="0" cellborder="1" cellspacing="0" cellpadding="6" bgcolor="#334155" color="#8b5cf6">
              <tr><td bgcolor="#334155" border="0"><b><font point-size="14" color="#f1f5f9">ProfileEngine</font></b></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Methods</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="registerDevice"><font color="#e2e8f0">registerDevice</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="cachedProfile"><font color="#e2e8f0">cachedProfile</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="displayProfile"><font color="#e2e8f0">displayProfile</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="hardwareProfile"><font color="#e2e8f0">hardwareProfile</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="profileForApp"><font color="#e2e8f0">profileForApp</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="setDisplayProfile"><font color="#e2e8f0">setDisplayProfile</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="setHardwareProfile"><font color="#e2e8f0">setHardwareProfile</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="saveProfileToDisk"><font color="#e2e8f0">saveProfileToDisk</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="createProfileForApp"><font color="#e2e8f0">createProfileForApp</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="removeAppProfile"><font color="#e2e8f0">removeAppProfile</font></td></tr>
              <tr><td bgcolor="#334155" border="0"><font color="#c4b5fd" point-size="10"><b>Signals</b></font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="deviceDisplayProfileChanged"><font color="#e2e8f0">deviceDisplayProfileChanged</font></td></tr>
              <tr><td bgcolor="#3f3a5e" align="left" port="deviceHardwareProfileChanged"><font color="#e2e8f0">deviceHardwareProfileChanged</font></td></tr>
            </table>
        >];
    }

    // ============ Signals ============
    // Signals out
    PE:deviceDisplayProfileChanged:w -> PO:onDisplayProfileChanged:e [color="#fcd34d"];

    // Orchestrator reads and writes
    PO:saveCurrentProfile:e    -> PE:saveProfileToDisk:w  [color="#c4b5fd", style=dashed, label=<<font color="#94a3b8">write</font>>];
    PO:setupProfileForDevice:e -> PE:registerDevice:w     [color="#c4b5fd", style=dashed];
    PO:onWindowFocusChanged:e  -> PE:profileForApp:w      [color="#c4b5fd", style=dashed, label=<<font color="#94a3b8">read</font>>];
    PO:onWindowFocusChanged:e  -> PE:setHardwareProfile:w [color="#c4b5fd", style=dashed];

    // Dispatcher reads for buttons + gestures
    BAD:readProfile:e -> PE:cachedProfile:w [color="#c4b5fd", style=dashed, label=<<font color="#94a3b8">read</font>>];

    // AppRoot lambda on ProfileModel add/remove
    AR:onProfileAddedRemoved:e -> PE:createProfileForApp:w [color="#c4b5fd", style=dashed];
    AR:onProfileAddedRemoved:e -> PE:removeAppProfile:w    [color="#c4b5fd", style=dashed];
}
