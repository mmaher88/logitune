# System Overview
# ---------------
# Rendered to system-overview.svg via `make diagrams` (runs d2).
# Edit this file, then regenerate. The CI lint + pre-push hook
# refuse to merge a stale SVG.
#
# Organization:
#   Five layers stacked top-to-bottom via grid-rows = 5. Each
#   layer's grid is laid out so the single node that bridges to
#   the layer above sits on the LEFT column, and the other
#   components fan out to the right. That way the only
#   cross-layer arrows are the six straight-up ones on the left
#   edge, and nothing else crosses. Commands flow back along
#   the same path — no need to duplicate arrows in the diagram.

grid-rows: 5
grid-columns: 1
grid-gap: 70

# ---------- Layer 1: QML UI ----------
ui: "QML UI" {
  grid-columns: 3
  main: "Main.qml"
  pages: "Pages\nPointScroll · Buttons\nEasySwitch · Settings"
  components: "Components\nDeviceRender · SideNav\nProfileBar"
}

# ---------- Layer 2: App ----------
app: "App library — logitune-app-lib" {
  grid-columns: 4
  device_model: "DeviceModel"
  button_model: "ButtonModel"
  action_filter_model: "ActionFilterModel"
  other_models: "ProfileModel\nSettingsModel"
  controller: "AppController"
  profile_engine: "ProfileEngine"
  tray: "TrayManager"
  editor: "EditorModel\n(--edit mode)"
}

# ---------- Layer 3: Core ----------
core: "Core library — logitune-core" {
  grid-columns: 3
  devmgr: "DeviceManager"
  physical: "PhysicalDevice"
  session: "DeviceSession"
  hidpp: "HID++ stack\nFeatureDispatcher · CommandQueue\nTransport · HidrawDevice"
  desktop: "Desktop integration\nKDeDesktop · GnomeDesktop\nGenericDesktop"
  inject: "Input injection\nUinputInjector"
}

# ---------- Layer 4: Kernel ----------
kernel: "Linux kernel" {
  grid-columns: 4
  hidraw: "/dev/hidrawN"
  udev: "libudev\n(hot-plug)"
  dbus: "D-Bus session bus\n(KWin / GNOME Shell)"
  uinput: "/dev/uinput\n(keystrokes)"
}

# ---------- Layer 5: Hardware ----------
hardware: "🖱️ Mouse hardware" {
  mice: "MX Master 3S · MX Master 4 · MX Anywhere · MX Vertical"
}

# ---------- Single upward narrative edge per layer boundary ----------
hardware.mice -> kernel.hidraw: "HID++ reports"
kernel.hidraw -> core.session: "read()"
core.devmgr -> app.controller: "Qt signals\n(stateChanged, activeWindowChanged, …)"
app.device_model -> ui.main: "QML binding"

# Commands flow back down along the same edges; shown in prose
# rather than duplicated arrows to keep the diagram legible.
